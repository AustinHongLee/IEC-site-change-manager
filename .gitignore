# 版本控制忽略檔案

# Python
__pycache__/
.pytest_cache/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
packaging/generated/
*.egg-info/
.eggs/
*.egg

# 虛擬環境
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系統
Thumbs.db
.DS_Store

# 暫存檔
*.tmp
*.temp
tmp_*.xlsx
~$*
*.bak
.project.lock
.project.lock.tmp
*.journal
.journals/

# 日誌
logs/*
!logs/.gitkeep
*.log

# 備份
backups/
records/material_pricebook.*.bak.json
records/material_pricebook.backup.json
records/material_pricebook.303.json
records/weld_snapshot.*.bak.json
records/sample_generation_summary.json

# 執行期狀態
settings.json
records/records.json
records/weld_snapshot.json
records/billing.json
records/billing_batches.json
records/app_settings.json
records/project_parts.json
attachments/*
!attachments/.gitkeep

# 前置區（照片暫存）
staging/*
!staging/.gitkeep

# 產出樣本/臨時標註
_annotated/
output/excel_samples/
output/owner_data_samples*/

# 安全隔離區
.trash/

# 不要上傳大型輸出檔案（可選，依需求調整）
# output/
# pdf/
