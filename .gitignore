# 版本控制忽略檔案

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
packaging/generated/
*.egg-info/
.eggs/
*.egg

# 虛擬環境
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系統
Thumbs.db
.DS_Store

# 暫存檔
*.tmp
*.temp
~$*
*.bak
.project.lock
.project.lock.tmp
*.journal
.journals/

# 日誌
logs/*
!logs/.gitkeep
*.log

# 備份
backups/
records/material_pricebook.*.bak.json
records/material_pricebook.backup.json
records/material_pricebook.303.json

# 執行期狀態
records/project_parts.json

# 前置區（照片暫存）
staging/*
!staging/.gitkeep

# 安全隔離區
.trash/

# 不要上傳大型輸出檔案（可選，依需求調整）
# output/
# pdf/
